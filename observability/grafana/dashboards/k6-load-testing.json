{
  "title": "k6 — Load Testing",
  "uid": "k6-load-testing",
  "tags": ["k6", "load-test", "performance"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Virtual Users (VUs)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "displayName": "VUs"
        }
      },
      "targets": [
        { "expr": "k6_vus", "legendFormat": "VUs ativos", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        { "expr": "rate(k6_http_reqs_total[30s])", "legendFormat": "req/s", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Taxa de Erros (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "k6_errors_rate", "legendFormat": "taxa de erros", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Checks Bem-Sucedidos",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "k6_checks_rate", "legendFormat": "checks ok", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Latência — p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p50",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "k6_http_req_duration_p99",
          "legendFormat": "p99", "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Requisições com Falha (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit"
        }
      },
      "targets": [
        { "expr": "k6_http_req_failed_rate", "legendFormat": "req com falha", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Dados Trafegados",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "Bps"
        }
      },
      "targets": [
        { "expr": "rate(k6_data_received_total[30s])", "legendFormat": "recebido", "refId": "A" },
        { "expr": "rate(k6_data_sent_total[30s])", "legendFormat": "enviado", "refId": "B" }
      ]
    },
    {
      "id": 8,
      "title": "Total de Requisições",
      "type": "stat",
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "k6_http_reqs_total", "legendFormat": "total req", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "title": "Iterações Completas",
      "type": "stat",
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "k6_iterations_total", "legendFormat": "iterações", "refId": "A" }
      ]
    }
  ]
}
